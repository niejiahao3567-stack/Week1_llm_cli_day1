# ============================================
# LLM CLI 调用工具 —— 环境变量配置模板
# ============================================
# 使用方法：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 填入你的真实 API Key 和地址
#   3. .env 不会被 Git 追踪（已在 .gitignore 中）
# ============================================

# （必填）LLM API Key，用于 Bearer Token 认证
LLM_API_KEY=

# （必填）LLM API 基础地址，不含 /v1/chat/completions 后缀
# 示例：
#   DeepSeek:   https://api.deepseek.com
#   通义千问:   https://dashscope.aliyuncs.com/compatible-mode
#   OpenAI:     https://api.openai.com
LLM_BASE_URL=

# （必填）模型名称
# 示例：deepseek-v4-pro / qwen-plus / gpt-4o
LLM_MODEL=